{
  "private": true,
  "name": "nextjs",
  "type": "module",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "dev:webpack": "next dev",
    "dev:debug": "cross-env NODE_OPTIONS=\"--inspect\" next dev --turbopack",
    "build": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" next build --webpack",
    "vercel-build": "drizzle-kit push && cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" next build --webpack",
    "build:analyze": "cross-env ANALYZE=true next build",
    "start": "next start",
    "start:prod": "cross-env NODE_ENV=production next start -p 3000",
    "build:productionlint": "eslint .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf .next .turbo .swc node_modules/.cache",
    "clean:hard": "rimraf .next .turbo .swc node_modules/.cache && pnpm store prune",
    "clean:all": "rimraf .next .turbo .swc node_modules/.cache node_modules && pnpm install --force",
    "clean:windows": "powershell -ExecutionPolicy Bypass -File cleanup.ps1",
    "reinstall": "pnpm clean:all",
    "fresh": "pnpm clean && pnpm dev",
    "fresh:build": "pnpm clean && pnpm build",
    "db:setup": "tsx scripts/setup-database.ts",
    "db:create-tables": "tsx scripts/create-pte-tables.ts",
    "db:seed": "tsx lib/db/seed.ts",
    "db:seed:speaking": "tsx lib/db/seed.ts --speaking --reset",
    "db:seed:all": "tsx lib/db/seed.ts --all --reset",
    "db:seed:pte": "tsx lib/db/seed-pte-data.ts",
    "db:check": "tsx scripts/check-data.ts",
    "db:test": "tsx scripts/test-connection.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:drop": "drizzle-kit drop",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "check": "turbo run test lint build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "sanity:deploy": "npx sanity deploy",
    "sanity:schema:deploy": "npx sanity schema deploy",
    "sanity:graphql:deploy": "npx sanity graphql deploy",
    "sanity:build": "npx sanity build",
    "sanity:typegen": "npx sanity typegen generate",
    "verify:practice": "tsx scripts/verify-practice-system.ts",
    "verify:scoring": "tsx scripts/test-scoring-logic.ts",
    "verify:comprehensive": "tsx scripts/comprehensive-test.ts",
    "deploy:checklist": "tsx scripts/deploy-checklist.ts",
    "deploy:verify": "pnpm deploy:checklist && pnpm verify:practice",
    "deploy:sanity": "pnpm sanity:schema:deploy && pnpm sanity:build",
    "deploy:script": "bash scripts/deploy.sh",
    "deploy:vercel": "pnpm deploy:verify && vercel --prod",
    "deploy:vercel:claim": "pnpm deploy:verify && pnpm deploy:script",
    "deploy:full": "pnpm deploy:verify && pnpm deploy:sanity && vercel --prod",
    "deploy:full:claim": "pnpm deploy:verify && pnpm deploy:sanity && pnpm deploy:script",
    "deploy:preview": "vercel",
    "db:seed:admin": "tsx scripts/seed-admin.ts",
    "db:seed:questions": "tsx scripts/seed-all-questions.ts",
    "blob:setup": "tsx scripts/setup-blob-folders.ts",
    "setup:all": "pnpm db:push && pnpm db:seed:admin && pnpm db:seed:questions && pnpm blob:setup",
    "deploy:setup": "pnpm db:push && pnpm db:seed:pte",
    "postbuild": "echo '✅ Build completed successfully!'",
    "postinstall": "echo '✅ Dependencies installed successfully!'"
  },
