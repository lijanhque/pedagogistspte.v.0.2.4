# Core
NODE_ENV=development

# =============================================================================
# Vercel System Environment Variables (Auto-injected by Vercel)
# =============================================================================
# These are automatically provided by Vercel - do NOT set manually in production
# Reference: https://vercel.com/docs/environment-variables/framework-environment-variables

# Server-side only (not exposed to browser)
# VERCEL=1
# VERCEL_ENV=production|preview|development
# VERCEL_URL=your-deployment.vercel.app
# VERCEL_REGION=iad1
# VERCEL_AUTOMATION_BYPASS_SECRET=
# VERCEL_BRANCH_URL=my-site-git-branch.vercel.app
# VERCEL_GIT_PROVIDER=github
# VERCEL_GIT_REPO_SLUG=my-repo
# VERCEL_GIT_REPO_OWNER=username
# VERCEL_GIT_REPO_ID=123456789
# VERCEL_GIT_COMMIT_REF=main
# VERCEL_GIT_COMMIT_SHA=abc123...
# VERCEL_GIT_COMMIT_MESSAGE=commit message
# VERCEL_GIT_COMMIT_AUTHOR_LOGIN=username
# VERCEL_GIT_COMMIT_AUTHOR_NAME=Full Name
# VERCEL_GIT_PULL_REQUEST_ID=123

# Client-side (exposed to browser via NEXT_PUBLIC_ prefix)
# NEXT_PUBLIC_VERCEL_ENV=production
# NEXT_PUBLIC_VERCEL_URL=your-deployment.vercel.app
# NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=your-domain.com
# NEXT_PUBLIC_VERCEL_BRANCH_URL=my-site-git-branch.vercel.app
# NEXT_PUBLIC_VERCEL_GIT_PROVIDER=github
# NEXT_PUBLIC_VERCEL_GIT_REPO_SLUG=my-repo
# NEXT_PUBLIC_VERCEL_GIT_REPO_OWNER=username
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_REF=main
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=abc123...

# Build-time environment variables (set in vercel.json)
# ENABLE_EXPERIMENTAL_COREPACK=1
# NODE_VERSION=20.17.0
# PNPM_VERSION=10.26.1

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://your_username:your_password@your_host.neon.tech:5432/your_database?sslmode=require

# Authentication (REQUIRED)
# Generate secret with: openssl rand -base64 48
# IMPORTANT: Use a strong 48+ character secret in production
BETTER_AUTH_SECRET=your_better_auth_secret_min_32_chars_recommended_48_plus
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Email Service (REQUIRED for production)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# AI Services - Google/Gemini
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key

# AI Services - Speech Recognition
ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# Vercel Blob Storage (Auto-created when you add Vercel Blob integration)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxx

# Redis / Upstash (Optional - for rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Monitoring (Rollbar - Optional)
ROLLBAR_PEDAGOGISTPTE_SERVER_TOKEN_1763820319=your_rollbar_token

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-01-06
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Mux (Video processing - Optional)
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret

# Payment Gateways
# =============================================================================

# Payment Gateway - Polar.sh (International/USD)
POLAR_ACCESS_TOKEN=your_polar_access_token
POLAR_PRO_PRODUCT_ID=your_polar_pro_product_id
POLAR_PREMIUM_PRODUCT_ID=your_polar_premium_product_id

# Payment Gateway - SSL Commerz (Bangladesh/BDT)
SSLCOMMERZ_STORE_ID=pedag68e7f09e3b442
SSLCOMMERZ_STORE_PASSWORD=pedag68e7f09e3b442@ssl
SSLCOMMERZ_IS_SANDBOX=true  # Set to 'false' for production

# Application URLs (used for payment callbacks)
BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000