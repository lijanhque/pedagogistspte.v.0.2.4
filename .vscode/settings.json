{
  "editor.formatOnSave": true,
  "editor.fontSize": 18,
  "window.autoDetectColorScheme": true,
  "accessibility.signalOptions.debouncePositionChanges": true,
  "telemetry.editStats.details.enabled": true,
  "files.autoSave": "afterDelay",
  "claudeCode.useTerminal": true,
  "coderabbit.agentType": "Native",
  "coderabbit.autoReviewMode": "auto",
  "github-actions.workflows.pinned.workflows": [
    ".github/workflows/preview.yml"
  ],
  "git.allowForcePush": true,
  "git.allowNoVerifyCommit": true,
  "git.alwaysShowStagedChangesResourceGroup": true,
  "git.alwaysSignOff": true,
  "github.codespaces.devcontainerChangedNotificationStyle": "modal",
  "githubIssues.alwaysPromptForNewIssueRepo": true,
  "sanity.useCDN": true,
  "sanity.openJSONFile": true,
  "extension.prophet.sitecontext.selectedSiteID": ""
}
